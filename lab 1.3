#include <iostream>
#include <cmath>
#include <iomanip>
using namespace std;

const double PI = 3.14159265358979323846;
const double a = 1e-10;

double compute_a(double x) {
    double total = 0.0;
    int k = 1;

    while (true) {
        double elem = 1.0 / (k * k + 1);
        if (elem < x) break;
        total += elem;
        k++;
    }
    return total;
}

int count_a(double x) {
    int k = 1;
    int cnt = 0;

    while (true) {
        double elem = 1.0 / (k * k + 1);
        cnt++;
        if (elem < x) break;
        k++;
    }
    return cnt;
}

double compute_b(double x) {
    double total = 0.0;
    int k = 1;

    while (true) {
        double elem = (1.0 / (k * k)) - (1.0 / (k * k * k * k + k * k));
        if (abs(elem) < x) break;
        total += elem;
        k++;
    }
    return total;
}

int count_b(double x) {
    int k = 1;
    int cnt = 0;

    while (true) {
        double elem = (1.0 / (k * k)) - (1.0 / (k * k * k * k + k * k));
        cnt++;
        if (abs(elem) < x) break;
        k++;
    }
    return cnt;
}

int main() {
    setlocale(LC_ALL, "russian");
    cout << fixed << setprecision(12);

    double orig_sum = compute_a(a);
    double mod_sum = compute_b(a);
    int orig_cnt = count_a(a);
    int mod_cnt = count_b(a);

    cout << "Сумма исходного ряда: " << orig_sum << endl;
    cout << "Сумма преобразованного ряда: " << mod_sum << endl;
    cout << "Разность: " << abs(orig_sum - mod_sum) << endl;
    cout << "Ускорение: " << (double)orig_cnt / mod_cnt << " раз" << endl;

}
