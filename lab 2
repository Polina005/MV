#include <iostream>
#include <cmath>
#include <limits>
#include <iomanip>
using namespace std;

double safe_discriminant(double a, double b, double c) {
    
    double max_val = max(fabs(a), max(fabs(b), fabs(c)));

    if (max_val == 0) return 0;

    // Масштабируем коэффициенты
    double scaled_a = a / max_val;
    double scaled_b = b / max_val;
    double scaled_c = c / max_val;

    double b2 = scaled_b * scaled_b;
    double ac4 = 4.0 * scaled_a * scaled_c;

    // Проверка на переполнение
    if (isinf(b2) || isinf(ac4)) {
        // Если всё ещё переполнение, используем логарифмический подход
        double log_b2 = 2.0 * log(fabs(scaled_b));
        double log_ac4 = log(4.0) + log(fabs(scaled_a)) + log(fabs(scaled_c));

        if (log_b2 > log_ac4 + 20) return max_val * max_val * scaled_b * scaled_b;
        if (log_ac4 > log_b2 + 20) return -max_val * max_val * 4.0 * scaled_a * scaled_c;
    }

    return max_val * max_val * (b2 - ac4);
}


void korni(double a, double b, double c) {
    cout << "Уравнение: ";
    if (a != 0) cout << a << "x^2 ";
    if (b != 0) cout << (b > 0 ? "+ " : "") << b << "x ";
    if (c != 0) cout << (c > 0 ? "+ " : "") << c;
    cout << " = 0" << endl;

    // Проверка на вырожденные случаи
    if (a == 0) {
        if (b == 0) {
            if (c == 0)
                cout << "Решение: x - любое число (тождество)" << endl;
            else
                cout << "Решений нет (противоречие)" << endl;
        }
        else {
            cout << "Линейное уравнение, корень: x = " << -c / b << endl;
        }
        return;
    }

    // Нормальный случай - квадратное уравнение
    double D = safe_discriminant(a, b, c);

    cout << "Дискриминант: " << D << endl;

    if (D < 0) {
        double real = -b / (2.0 * a);
        double imag = sqrt(-D) / (2.0 * fabs(a));
        cout << "Комплексные корни:" << endl;
        cout << "x1 = " << real << " + " << imag << "i" << endl;
        cout << "x2 = " << real << " - " << imag << "i" << endl;
    }
    else if (D == 0) {
        double x = -b / (2.0 * a);
        cout << "Один корень (кратности 2): x = " << x << endl;
    }
    else {
        // Используем устойчивую формулу для избежания потери значимости
        double sqrt_D = sqrt(D);
        double x1, x2;

        if (b >= 0) {
            x1 = (-b - sqrt_D) / (2.0 * a);
            x2 = (2.0 * c) / (-b - sqrt_D);
        }
        else {
            x1 = (-b + sqrt_D) / (2.0 * a);
            x2 = (2.0 * c) / (-b + sqrt_D);
        }

        cout << "Два действительных корня:" << endl;
        cout << "x1 = " << x1 << endl;
        cout << "x2 = " << x2 << endl;
    }
    cout << "------------------------" << endl;
}

int main() {
    setlocale(LC_ALL, "russian");
    cout << fixed << setprecision(10);

    korni(1, -3, 2);      // x² - 3x + 2 = 0 (корни 1, 2)
    korni(1, 2, 1);       // x² + 2x + 1 = 0 (корень -1)
    korni(1, 0, -1);      // x² - 1 = 0 (корни ±1)
    korni(2, 5, 3);       // 2x² + 5x + 3 = 0

}
